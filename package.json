{
  "name": "touchline-relay",
  "productName": "Touchline Relay",
  "version": "1.0.0",
  "upgrade": "pear://<YOUR_KEY_HERE>",
  "updates": false,
  "description": "Local-first tournament announcement relay with QVAC translation and Hyperswarm P2P delivery.",
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "test": "node --test test/*.test.js",
    "qvac:smoke": "node scripts/qvac-smoke.js",
    "lint": "prettier --check . && lunte electron lib renderer scripts test workers forge.config.js",
    "format": "prettier --write . && lunte --fix electron lib renderer scripts test workers forge.config.js",
    "start": "electron-forge start -- --no-updates --no-sandbox",
    "start:demo-a": "electron-forge start -- --no-updates --storage /tmp/touchline-a --no-sandbox",
    "start:demo-b": "electron-forge start -- --no-updates --storage /tmp/touchline-b --no-sandbox",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:zip": "electron-forge make --targets=@electron-forge/maker-zip",
    "release:linux-folder": "npm run package && node -e \"console.log('Package ready under out/')\""
  },
  "dependencies": {
    "@qvac/sdk": "^0.14.1",
    "b4a": "^1.8.1",
    "corestore": "^7.9.1",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hello-pear-worker": "^1.0.0",
    "hypercore-crypto": "^3.7.0",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.4",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "app-builder-lib": "^26.8.1",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "lunte": "^1.6.0",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-electron-forge-maker-flatpak": "^0.0.6",
    "pear-electron-forge-maker-snap": "^1.0.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0"
  },
  "allowScripts": {
    "electron@40.10.1": true,
    "electron-winstaller": false
  }
}
